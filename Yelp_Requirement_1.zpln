dateIntervalMs":500,"jobName":"paragraph_1774417424272_1420358124","id":"paragraph_1774417424272_1420358124","dateCreated":"2026-03-25T13:43:44+0800","dateStarted":"2026-03-25T13:46:57+0800","dateFinished":"2026-03-25T13:51:32+0800","status":"FINISHED"},{"text":"%md\n### Finding — IV-a: Rating Differential (Merchant vs Category Average)\n\n**Hidden Gems (Above Average):**\n- Arthur's In Home TV Repair (Tampa) stands out **+3.45 above** category average\n- Many 5-star real estate and service businesses significantly outperform their peers\n\n**Underperformers (Below Average):**\n- Trunorth Photography (Boise) is **-3.66 below** category average — worst performer\n- Pet sitting and fitness businesses show the largest negative differentials\n- These businesses are in **high-rated categories** but received very low scores","user":"anonymous","dateUpdated":"2026-03-25T13:56:10+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"markdown","editOnDblClick":true,"completionKey":"TAB","completionSupport":false}},"settings":{"params":{},"forms":{}},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774417496370_384819036","id":"paragraph_1774417496370_384819036","dateCreated":"2026-03-25T13:44:56+0800","status":"READY"},{"text":"%md\n# Section V: Check-in Analysis","user":"anonymous","dateUpdated":"2026-03-25T13:56:39+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"markdown","editOnDblClick":true,"completionSupport":false}},"settings":{"params":{},"forms":{}},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774418178675_1116267860","id":"paragraph_1774418178675_1116267860","dateCreated":"2026-03-25T13:56:18+0800","status":"READY"},{"text":"%pyspark\r\nfrom pyspark.sql.functions import col, month, count, explode, split, avg\r\n\r\n# Join reviews with business to get cuisine categories\r\nreview_with_cuisine = review_df.join(\r\n    business_df.select(\"business_id\", \"categories\"),\r\n    on=\"business_id\", how=\"inner\"\r\n).filter(col(\"categories\").isNotNull())\r\n\r\n# Focus on 3 main cuisine types\r\ncuisine_keywords = {\r\n    \"Chinese\": \"Chinese\",\r\n    \"Mexican\": \"Mexican\",\r\n    \"American\": \"American (Traditional)\"\r\n}\r\n\r\n# Get monthly review counts per cuisine\r\nfrom pyspark.sql.functions import when, lit\r\n\r\nreview_with_cuisine = review_with_cuisine.withColumn(\r\n    \"cuisine\",\r\n    when(col(\"categories\").contains(\"Chinese\"), \"Chinese\")\r\n    .when(col(\"categories\").contains(\"Mexican\"), \"Mexican\")\r\n    .when(col(\"categories\").contains(\"American (Traditional)\") |\r\n          col(\"categories\").contains(\"American (New)\"), \"American\")\r\n    .otherwise(None)\r\n).filter(col(\"cuisine\").isNotNull())\r\n\r\n# Monthly seasonality\r\nseasonality = review_with_cuisine \\\r\n    .withColumn(\"month\", month(col(\"date\"))) \\\r\n    .groupBy(\"month\", \"cuisine\") \\\r\n    .agg(count(\"*\").alias(\"review_count\")) \\\r\n    .orderBy(\"cuisine\", \"month\")\r\n\r\nprint(\"=== Review Seasonality by Cuisine (Monthly) ===\")\r\nseasonality.show(40, truncate=False)\r\nz.show(seasonality)","user":"anonymous","dateUpdated":"2026-03-25T14:03:36+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"1":{"graph":{"mode":"lineChart","height":300,"optionOpen":false,"setting":{"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{},"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false}},"keys":[{"name":"month","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"cuisine","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"=== Review Seasonality by Cuisine (Monthly) ===\n+-----+--------+------------+\n|month|cuisine |review_count|\n+-----+--------+------------+\n|1    |American|137822      |\n|2    |American|126238      |\n|3    |American|138614      |\n|4    |American|126348      |\n|5    |American|134272      |\n|6    |American|138027      |\n|7    |American|149284      |\n|8    |American|142859      |\n|9    |American|128472      |\n|10   |American|129556      |\n|11   |American|121542      |\n|12   |American|121794      |\n|1    |Chinese |21707       |\n|2    |Chinese |18515       |\n|3    |Chinese |19117       |\n|4    |Chinese |17286       |\n|5    |Chinese |17971       |\n|6    |Chinese |17682       |\n|7    |Chinese |19517       |\n|8    |Chinese |19575       |\n|9    |Chinese |17605       |\n|10   |Chinese |18179       |\n|11   |Chinese |17339       |\n|12   |Chinese |19772       |\n|1    |Mexican |35864       |\n|2    |Mexican |33260       |\n|3    |Mexican |37304       |\n|4    |Mexican |34821       |\n|5    |Mexican |38363       |\n|6    |Mexican |38150       |\n|7    |Mexican |41772       |\n|8    |Mexican |39922       |\n|9    |Mexican |35244       |\n|10   |Mexican |34513       |\n|11   |Mexican |30993       |\n|12   |Mexican |31440       |\n+-----+--------+------------+\n\n"},{"type":"TABLE","data":"month\tcuisine\treview_count\n1\tAmerican\t137822\n2\tAmerican\t126238\n3\tAmerican\t138614\n4\tAmerican\t126348\n5\tAmerican\t134272\n6\tAmerican\t138027\n7\tAmerican\t149284\n8\tAmerican\t142859\n9\tAmerican\t128472\n10\tAmerican\t129556\n11\tAmerican\t121542\n12\tAmerican\t121794\n1\tChinese\t21707\n2\tChinese\t18515\n3\tChinese\t19117\n4\tChinese\t17286\n5\tChinese\t17971\n6\tChinese\t17682\n7\tChinese\t19517\n8\tChinese\t19575\n9\tChinese\t17605\n10\tChinese\t18179\n11\tChinese\t17339\n12\tChinese\t19772\n1\tMexican\t35864\n2\tMexican\t33260\n3\tMexican\t37304\n4\tMexican\t34821\n5\tMexican\t38363\n6\tMexican\t38150\n7\tMexican\t41772\n8\tMexican\t39922\n9\tMexican\t35244\n10\tMexican\t34513\n11\tMexican\t30993\n12\tMexican\t31440\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=153"},{"jobUrl":"http://node-master:4040/jobs/job?id=154"},{"jobUrl":"http://node-master:4040/jobs/job?id=155"},{"jobUrl":"http://node-master:4040/jobs/job?id=156"},{"jobUrl":"http://node-master:4040/jobs/job?id=157"},{"jobUrl":"http://node-master:4040/jobs/job?id=158"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774418193337_686935656","id":"paragraph_1774418193337_686935656","dateCreated":"2026-03-25T13:56:33+0800","dateStarted":"2026-03-25T13:56:52+0800","dateFinished":"2026-03-25T14:01:02+0800","status":"FINISHED"},{"text":"%md\n### Finding — V-a: Review Seasonality by Cuisine\n\n- **July is peak month** for all 3 cuisines — summer dining is most active\n- **November & December are slowest** — holiday season people dine at home\n- **American** dominates with 10x more reviews than Chinese\n- **Mexican** peaks in May-July — aligns with Cinco de Mayo and summer\n- **Chinese** spikes in December — likely Christmas/New Year celebrations","user":"anonymous","dateUpdated":"2026-03-25T14:04:54+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"markdown","editOnDblClick":true,"completionSupport":false}},"settings":{"params":{},"forms":{}},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774418177442_1897322429","id":"paragraph_1774418177442_1897322429","dateCreated":"2026-03-25T13:56:17+0800","status":"READY"},{"text":"%md\n# Section VI: Comprehensive Analysis","user":"anonymous","dateUpdated":"2026-03-25T14:05:08+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"markdown","editOnDblClick":true,"completionSupport":false}},"settings":{"params":{},"forms":{}},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774418170518_1150286902","id":"paragraph_1774418170518_1150286902","dateCreated":"2026-03-25T13:56:10+0800","status":"READY"},{"text":"%pyspark\nfrom pyspark.sql.functions import col, split, explode, trim, to_timestamp, \\\n    count, avg, datediff, min as _min, max as _max, round as _round\n\n# Parse checkin dates — they are comma separated strings\ncheckin_parsed = checkin_df \\\n    .withColumn(\"date_array\", split(col(\"date\"), \", \")) \\\n    .withColumn(\"checkin_date\", explode(col(\"date_array\"))) \\\n    .withColumn(\"checkin_date\", trim(col(\"checkin_date\"))) \\\n    .withColumn(\"checkin_ts\", to_timestamp(col(\"checkin_date\"), \"yyyy-MM-dd HH:mm:ss\")) \\\n    .select(\"business_id\", \"checkin_ts\")\n\n# Get first and last review date per business\nreview_dates = review_df.groupBy(\"business_id\").agg(\n    _min(\"date\").alias(\"first_review_date\"),\n    _max(\"date\").alias(\"last_review_date\"),\n    count(\"*\").alias(\"total_reviews\")\n)\n\n# Get checkin counts before and after first review\ncheckin_with_review = checkin_parsed.join(\n    review_dates, on=\"business_id\", how=\"inner\"\n)\n\n# Count checkins before vs after first review\nfrom pyspark.sql.functions import when, sum as _sum\n\ncheckin_before_after = checkin_with_review.withColumn(\n    \"period\",\n    when(col(\"checkin_ts\") < col(\"first_review_date\").cast(\"timestamp\"), \"before_first_review\")\n    .otherwise(\"after_first_review\")\n).groupBy(\"business_id\", \"period\") \\\n .agg(count(\"*\").alias(\"checkin_count\"))\n\n# Pivot to get before/after columns side by side\nfrom pyspark.sql.functions import lit\npivot_df = checkin_before_after.groupBy(\"business_id\").pivot(\"period\") \\\n    .agg(count(\"checkin_count\")) \\\n    .fillna(0)\n\n# Calculate drop-off\ndropoff_df = pivot_df.withColumn(\n    \"dropoff_%\",\n    _round(\n        (col(\"before_first_review\") - col(\"after_first_review\")) /\n        (col(\"before_first_review\") + lit(1)) * 100, 2\n    )\n).orderBy(\"dropoff_%\", ascending=False)\n\nprint(\"=== Post-Review Check-in Drop-off Analysis ===\")\ndropoff_df.show(20, truncate=False)\nz.show(dropoff_df.limit(20))\n\n# Summary stats\nprint(\"\\n=== Summary ===\")\ndropoff_df.agg(\n    avg(\"dropoff_%\").alias(\"avg_dropoff_%\"),\n    avg(\"before_first_review\").alias(\"avg_checkins_before\"),\n    avg(\"after_first_review\").alias(\"avg_checkins_after\")\n).show()","user":"anonymous","dateUpdated":"2026-03-25T14:08:27+0800","progress":0,"config":{"tableHide":false,"editorSetting":{"language":"python","editOnDblClick":false,"completionSupport":true,"completionKey":"TAB"},"colWidth":12,"fontSize":9,"editorHide":false,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"=== Post-Review Check-in Drop-off Analysis ===\n+----------------------+------------------+-------------------+---------+\n|business_id           |after_first_review|before_first_review|dropoff_%|\n+----------------------+------------------+-------------------+---------+\n|-6bu2SPTnFfgpk9ReLWmXw|0                 |1                  |50.0     |\n|-FW5ejFjgXH08xQapUiG5Q|0                 |1                  |50.0     |\n|-6eBL83GDj45MpRmiMN-FQ|0                 |1                  |50.0     |\n|1fnBN-SjPWGezSMjCy6GoA|0                 |1                  |50.0     |\n|-rvrCr6I-TyzVuw_BYOJhQ|0                 |1                  |50.0     |\n|-HKd0EkR6Sf9dRWnq9YjhA|0                 |1                  |50.0     |\n|00wzebOSS8CP4DoIagh8Hw|0                 |1                  |50.0     |\n|-AYNJCQci8Tn0y0B_z1PAQ|0                 |1                  |50.0     |\n|-70_fKY04n-BJbItDIclVg|0                 |1                  |50